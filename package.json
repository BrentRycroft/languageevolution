{
  "name": "languageevolution",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --base /languageevolution/",
    "test": "vitest run",
    "test:slow": "RUN_SLOW=1 vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "audit:divergence": "tsx scripts/audit-divergence.ts",
    "audit:length": "tsx scripts/audit-length.ts",
    "audit:narrative": "tsx scripts/audit-narrative.ts",
    "bench": "tsx scripts/bench-sim.ts"
  },
  "dependencies": {
    "d3-delaunay": "^6.0.4",
    "d3-hierarchy": "^3.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3-delaunay": "^6.0.4",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "fake-indexeddb": "^6.2.5",
    "fast-check": "^4.7.0",
    "jsdom": "^29.0.2",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^2.0.3"
